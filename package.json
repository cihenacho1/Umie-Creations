{
  "name": "umie-creations",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "css:build": "tailwindcss -i ./src/app/globals.css -o ./src/styles/tailwind.css --minify",
    "css:watch": "tailwindcss -i ./src/app/globals.css -o ./src/styles/tailwind.css --watch",
    "dev": "node scripts/start-next-dev.cjs",
    "dev:fresh": "rm -rf .next && npm run dev",
    "dev:fresh-clear-port": "rm -rf .next && npm run dev",
    "dev:turbopack": "node scripts/start-next-dev.cjs --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^6.1.0",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.12.0",
    "motion": "^12.38.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "stripe": "^17.5.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "kill-port": "^2.0.1",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
